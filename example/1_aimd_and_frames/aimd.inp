&FORCE_EVAL
   &SUBSYS
      &KIND Cl
         BASIS_SET TZV2P-GTH-q7
         POTENTIAL GTH-PBE-q7
      &END KIND
      &KIND Na
         BASIS_SET TZV2P-GTH-q9
         POTENTIAL GTH-PBE-q9
      &END KIND
      &KIND C
         BASIS_SET DZVP-MOLOPT-SR-GTH
         POTENTIAL GTH-PBE-q4
      &END KIND
      &KIND O
         BASIS_SET TZV2P-GTH-q6
         POTENTIAL GTH-PBE-q6
      &END KIND
      &KIND H
         MASS 2.0
         BASIS_SET TZV2P-GTH-q1
         POTENTIAL GTH-PBE-q1
      &END KIND
      &CELL
         ABC 12.3500001855 12.8339988918 31.7499986937
         PERIODIC XYZ
      &END CELL
      &TOPOLOGY
         COORD_FILE_FORMAT XYZ
         COORD_FILE_NAME trajectory-input.xyz
         CONN_FILE_FORMAT OFF
      &END TOPOLOGY
   &END SUBSYS
   &DFT
      BASIS_SET_FILE_NAME GTH_BASIS_SETS
      BASIS_SET_FILE_NAME BASIS_MOLOPT
      POTENTIAL_FILE_NAME POTENTIAL
      &XC
         &VDW_POTENTIAL
            POTENTIAL_TYPE PAIR_POTENTIAL
            &PAIR_POTENTIAL
               TYPE DFTD3
               R_CUTOFF 15.0
               LONG_RANGE_CORRECTION .TRUE.
               REFERENCE_FUNCTIONAL revPBE
               PARAMETER_FILE_NAME dftd3.dat
            &END PAIR_POTENTIAL
         &END VDW_POTENTIAL
         &XC_GRID
            XC_DERIV SPLINE2_SMOOTH
         &END XC_GRID
         &XC_FUNCTIONAL
            &PBE
               PARAMETRIZATION REVPBE
            &END PBE
         &END XC_FUNCTIONAL
      &END XC
      &QS
         EPS_DEFAULT 1e-12
         EPS_PGF_ORB 1e-14
      &END QS
      &SCF
         SCF_GUESS ATOMIC
         MAX_SCF 20
         EPS_SCF 5e-07
         ADDED_MOS 20
         &PRINT
            &RESTART
               ADD_LAST NUMERIC
               &EACH
                  QS_SCF 0
               &END EACH
            &END RESTART
         &END PRINT
         &OUTER_SCF
            MAX_SCF 20
            EPS_SCF 5e-07
         &END OUTER_SCF
         &MIXING
            METHOD BROYDEN_MIXING
            ALPHA 0.4
            BETA 0.5
            NBUFFER 8
         &END MIXING
         &DIAGONALIZATION
            ALGORITHM STANDARD
         &END DIAGONALIZATION
         &SMEAR .TRUE.
            METHOD FERMI_DIRAC
            ELECTRONIC_TEMPERATURE 300.0
         &END SMEAR
      &END SCF
      &MGRID
         CUTOFF 1200.0
         NGRIDS 5
      &END MGRID
   &END DFT
&END FORCE_EVAL

&MOTION
   &PRINT
      &TRAJECTORY
         FILENAME =trajectory-output.xyz
         &EACH
            MD 1
         &END EACH
      &END TRAJECTORY
      &VELOCITIES
         FILENAME =velocities-output.xyz
         &EACH
            MD 1
         &END EACH
      &END VELOCITIES
      &FORCES
         FILENAME =forces-output.xyz
         &EACH
            MD 1
         &END EACH
      &END FORCES
      # Always print the cell so every frame carries its cell (NVT or NPT).
      # FILENAME =aimd.cell fixes the name (no PROJECT prefix / -N counter),
      # matching cell_file="aimd.cell" in stage 2 (run_select_frames.py).
      &CELL
         FILENAME =aimd.cell
         &EACH
            MD 1
         &END EACH
      &END CELL
      &RESTART
         ADD_LAST NUMERIC
         &EACH
            MD 100
         &END EACH
      &END RESTART
      &RESTART_HISTORY
         &EACH
            MD 1000
         &END EACH
      &END RESTART_HISTORY
   &END PRINT
   &MD
      ENSEMBLE NVT
      STEPS 10
      TIMESTEP 0.5
      TEMPERATURE 300.0
      &THERMOSTAT
         TYPE CSVR
         REGION GLOBAL
         &CSVR
            TIMECON 100.0
         &END CSVR
      &END THERMOSTAT
   &END MD
&END MOTION

&GLOBAL
   PRINT_LEVEL LOW
   RUN_TYPE MD
   PROJECT_NAME aimd
&END GLOBAL

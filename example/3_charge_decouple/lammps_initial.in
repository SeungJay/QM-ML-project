log lammps_run.log

units real
dimension 3
atom_style full
boundary p p f
neigh_modify every 1 delay 0 check yes
kspace_style pppm 1.0e-5
kspace_modify slab 3.0

# Read the topology generated by createdatalammps (inside run_coulomb)
read_data lammps-data.txt

pair_style coul/long 10.0
pair_coeff * *

# Set target point charges (edit for your system / atom types)
set type 1 charge 0.0
set type 2 charge -0.834
set type 3 charge 0.417
set type 4 charge 1.0
set type 5 charge -1.0

group carbons type 1
group elyte type 2 3 4 5

# ---- DFT-CES coupling ---- (grid syntax as in base.in.lammps)
fix             solvGrid elyte gridforce -1 1     # scale -1 (qm convention), no-supercell
fix_modify      solvGrid energy yes               # include grid energy in the LAMMPS total
grid            V_ryd_initial.cube      # read potential; MDrho.cube is written automatically

dump mydump all custom 1 final.lammpstrj id type xu yu zu fx fy fz
dump_modify mydump sort id
thermo_style custom pe ke etotal ecoul elong evdwl f_solvGrid
thermo_modify line multi
thermo 1

run 0

# Coulomb (DFT-CES) template for run_coulomb(). Per structure it becomes an
# embedded run (electrode in the electrolyte EXTERNAL_POTENTIAL, READ_FROM_CUBE)
# plus a baseline run (electrode alone, with the &EXTERNAL_POTENTIAL block
# removed). Keep the commented &EXTERNAL_POTENTIAL block below so it can be
# toggled, and keep the V_HARTREE_CUBE + FORCES output. Only the electrode (C) is
# treated by CP2K; the electrolyte is LAMMPS point charges.
&FORCE_EVAL
   &SUBSYS
      &KIND C
         ELEMENT C
         BASIS_SET DZVP-MOLOPT-SR-GTH
         POTENTIAL GTH-PBE-q4
      &END KIND
      &CELL
         ABC 12.3500010801 12.8340008798 31.7500009857
         PERIODIC XYZ
      &END CELL
      &TOPOLOGY
         COORD_FILE_FORMAT XYZ
         COORD_FILE_NAME trajectory-input.xyz
         CONN_FILE_FORMAT OFF
      &END TOPOLOGY
   &END SUBSYS
   &DFT
      BASIS_SET_FILE_NAME GTH_BASIS_SETS
      BASIS_SET_FILE_NAME BASIS_MOLOPT
      POTENTIAL_FILE_NAME POTENTIAL
      SURFACE_DIPOLE_CORRECTION T
      SURF_DIP_DIR Z
#     &EXTERNAL_POTENTIAL
#        READ_FROM_CUBE T
#     &END EXTERNAL_POTENTIAL
      &XC
         &VDW_POTENTIAL
            POTENTIAL_TYPE PAIR_POTENTIAL
            &PAIR_POTENTIAL
               TYPE DFTD3
               R_CUTOFF 15.0
               LONG_RANGE_CORRECTION .TRUE.
               REFERENCE_FUNCTIONAL revPBE
               PARAMETER_FILE_NAME dftd3.dat
            &END PAIR_POTENTIAL
         &END VDW_POTENTIAL
         &XC_GRID
            XC_DERIV SPLINE2_SMOOTH
         &END XC_GRID
         &XC_FUNCTIONAL
            &PBE
               PARAMETRIZATION REVPBE
            &END PBE
         &END XC_FUNCTIONAL
      &END XC
      &QS
         EPS_DEFAULT 1e-12
         EPS_PGF_ORB 1e-14
      &END QS
      &SCF
         SCF_GUESS ATOMIC        # RESTART (with a pre-converged wfn) is faster
         MAX_SCF 20
         EPS_SCF 5e-07
         ADDED_MOS 20
         &OUTER_SCF
            MAX_SCF 20
            EPS_SCF 5e-07
         &END OUTER_SCF
         &MIXING
            METHOD BROYDEN_MIXING
            ALPHA 0.4
            BETA 0.5
            NBUFFER 8
         &END MIXING
         &DIAGONALIZATION
            ALGORITHM STANDARD
         &END DIAGONALIZATION
         &SMEAR .TRUE.
            METHOD FERMI_DIRAC
            ELECTRONIC_TEMPERATURE 300.0
         &END SMEAR
      &END SCF
      &MGRID
         CUTOFF 1200.0
         NGRIDS 5
      &END MGRID
      &PRINT
         &V_HARTREE_CUBE
            STRIDE 1
            FILENAME V_hartree.cube
         &END V_HARTREE_CUBE
      &END PRINT
   &END DFT
&END FORCE_EVAL

&MOTION
   &PRINT
      &FORCES
         FILENAME =forces-output.xyz
         &EACH
            MD 1
         &END EACH
      &END FORCES
   &END PRINT
   &MD
      STEPS 0
   &END MD
&END MOTION

&GLOBAL
   PRINT_LEVEL LOW
   RUN_TYPE MD
   PROJECT_NAME step-0
&END GLOBAL

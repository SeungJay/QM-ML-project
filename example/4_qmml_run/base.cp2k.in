#input

&GLOBAL
  PROJECT confined-NaClWatCarb-revPBE-D3
  PREFERRED_FFT_LIBRARY FFTW
  FFTW_PLAN_TYPE MEASURE
  PREFERRED_DIAG_LIBRARY ELPA
  RUN_TYPE ENERGY_FORCE
  #PRINT_LEVEL LOW
&END GLOBAL

&FORCE_EVAL
  &DFT
    #&EXTERNAL_POTENTIAL 
    #    READ_FROM_CUBE T
    #&END EXTERNAL_POTENTIAL
    BASIS_SET_FILE_NAME GTH_BASIS_SETS 
    BASIS_SET_FILE_NAME BASIS_MOLOPT 
    POTENTIAL_FILE_NAME POTENTIAL 
    SURFACE_DIPOLE_CORRECTION T
    SURF_DIP_DIR Z
    #SURF_DIP_POS Dipc_position
    &MGRID
      CUTOFF 1200
      NGRIDS 5
    &END MGRID
    &SCF
      # needs a pre-converged wfn as input
      SCF_GUESS RESTART
      #SCF_GUESS ATOMIC
      MAX_SCF 200
      EPS_SCF 5.0E-7 
      ADDED_MOS 20
      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 300
      &END SMEAR
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA   0.4
        BETA    0.5
        NBROYDEN  8
      &END 
      #&OT
      #  MINIMIZER DIIS
      #  PRECONDITIONER FULL_ALL
      #&END OT
      &OUTER_SCF
        MAX_SCF 200
        EPS_SCF 5.0E-7
      &END OUTER_SCF
    &END SCF
    &QS 
      EPS_DEFAULT 1.0E-12
      EPS_PGF_ORB 1.0E-14
    &END QS
    &XC # revPBE
      &XC_FUNCTIONAL
        &PBE 
          PARAMETRIZATION REVPBE
        &END
      &END XC_FUNCTIONAL
      &XC_GRID
        XC_DERIV SPLINE2_SMOOTH
      &END XC_GRID
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3
          R_CUTOFF 15
          LONG_RANGE_CORRECTION TRUE
          REFERENCE_FUNCTIONAL revPBE
          PARAMETER_FILE_NAME dftd3.dat
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
    &PRINT
        #&TOT_DENSITY_CUBE
	#  STRIDE 1
        #  FILENAME Tot_den.cube
        #&END TOT_DENSITY_CUBE
        &E_DENSITY_CUBE
	  STRIDE 1
          FILENAME Val_den.cube
        &END E_DENSITY_CUBE
        &V_HARTREE_CUBE
	  STRIDE 1
          FILENAME V_hartree.cube
        &END V_HARTREE_CUBE
    &END PRINT
  &END DFT
  &SUBSYS
    &CELL
      A 12.35000018552732 0.0 0.0
      B 0.0 12.833998891836368 0.0
      C 0.0 0.0 21.7000000410457
      PERIODIC XYZ
    &END CELL
    &TOPOLOGY                    ! Section used to center the atomic coordinates in the given box. Useful for big molecules
      #CONN_FILE_FORMAT AMBER
      CONN_FILE_FORMAT OFF
      #CONN_FILE_NAME MQAE.prmtop
      COORD_FILE_FORMAT XYZ 
      COORD_FILE_NAME data.cp2k 
    &END TOPOLOGY
    &KIND C
      ELEMENT C
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q4
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
